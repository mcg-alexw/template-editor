{
  "name": "template-editor",
  "version": "0.2.3",
  "description": "A React-based template editor with rich text editing capabilities.",
  "private": true,
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@tiptap/core": "^3.7.2",
    "@tiptap/extension-color": "^3.7.2",
    "@tiptap/extension-highlight": "^3.7.2",
    "@tiptap/extension-text-style": "^3.7.2",
    "@tiptap/pm": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "react": "^19.2.0",
    "react-color-palette": "^7.3.1",
    "react-dom": "^19.2.0"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write .",
    "prebuild": "yarn version patch",
    "build": "yarn prebuild && vite build",
    "preview": "vite preview",
    "deploy": "yarn build && gh-pages -d dist",
    "postinstall": "husky",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "src/**/*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.5.0",
    "@tailwindcss/cli": "^4.1.16",
    "@tailwindcss/vite": "^4.1.16",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12"
  },
  "packageManager": "yarn@4.10.3"
}
